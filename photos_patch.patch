-+    "import matplotlib as mpl\n",
-+    "mpl.rcParams.update({\n",
-+    "    'figure.facecolor': 'none', 'axes.facecolor': 'none',\n",
-+    "    'savefig.facecolor': 'none', 'savefig.transparent': True,\n",
